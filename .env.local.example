# Chamei — environment variables. Copy to app/.env.local for local dev; set the
# same in the Vercel project for production. NEXT_PUBLIC_* are inlined at build
# time (a redeploy is required after changing them).

# --- Database (Neon Postgres) ---
DATABASE_URL=postgres://user:pass@host/db?sslmode=require

# --- Admin panel (/admin) ---
# Password to log into /admin; ADMIN_SECRET signs the session cookie + admin API
# tokens (used by middleware/proxy and the x-admin-secret header for automation).
ADMIN_PASSWORD=change-me
ADMIN_SECRET=long-random-secret

# --- SMS verification (profile claim via /api/verify) — Twilio ---
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# --- WhatsApp Business (optional) ---
META_ACCESS_TOKEN=
META_PHONE_NUMBER_ID=

# --- Microsoft Clarity (heatmaps / session recordings) ---
# Project id from clarity.microsoft.com → Settings. Leave empty to disable.
NEXT_PUBLIC_CLARITY_ID=

# --- Google Places seeding (scripts/seed-places.mjs, optional) ---
GOOGLE_PLACES_API_KEY=
